---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
const projects = await getCollection('inDevelopment');
projects.sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
---

<Base title="In Development | Demetris Yiapanis">
  <h2 class="page-title">In Development</h2>
  <p class="page-subtitle">Current slate of projects in various stages of development</p>

  <div style="margin-top: 2rem;">
    {projects.length > 0 ? (
      <div class="grid-2">
        {projects.map(p => <article class="card">
          {p.data.poster ? (
            <div style="aspect-ratio: 3/2; overflow: hidden; margin: -2rem -2rem 1.5rem -2rem;">
              <img src={p.data.poster} alt={`${p.data.title} visual`} style="width:100%; height:100%; object-fit:cover;" />
            </div>
          ) : null}
          <div style="display:flex; justify-content:space-between; align-items:start; margin-bottom:1rem;">
            <h3 style="font-family: var(--font-display); font-weight: 400; font-size: 1.2rem; margin:0;">{p.data.title}</h3>
            <span style="font-size:0.7rem; text-transform:uppercase; letter-spacing:0.1em; color:var(--accent); border:1px solid var(--border); padding:0.3rem 0.6rem; white-space:nowrap; margin-left:1rem;">
              {p.data.status}
            </span>
          </div>
          <p style="font-size:0.85rem; color:var(--muted); margin-bottom:1rem;">{p.data.logline}</p>
          <p style="font-size:0.75rem; color:var(--muted);">{p.data.genre && p.data.genre.join(' • ')} {p.data.type && `• ${p.data.type}`}</p>
        </article>)}
      </div>
    ) : (
      <div class="card" style="text-align:center; padding: 4rem;">
        <p style="color: var(--muted); font-style: italic;">Projects will appear here as they enter development.</p>
      </div>
    )}
  </div>

  <section style="margin-top: 3rem;">
    <hr style="border: none; border-top: 1px solid var(--border); margin-bottom: 3rem;" />
    
    <h2 class="section-title">Enquiries</h2>
    
    <form action="/api/contact" method="POST" style="max-width: 500px;">
      <p style="margin-bottom: 1.5rem; color: var(--muted); font-size: 0.9rem;">Interested in any of these projects? Get in touch.</p>
      
      <label class="field-label" for="dev-name">Name *</label>
      <input class="field-input" type="text" id="dev-name" name="name" placeholder="Your name" required />
      
      <label class="field-label" for="dev-email" style="margin-top: 1rem;">Email *</label>
      <input class="field-input" type="email" id="dev-email" name="email" placeholder="your@email.com" required />
      
      <label class="field-label" for="dev-message" style="margin-top: 1rem;">Message *</label>
      <textarea class="field-input" id="dev-message" name="message" rows="5" placeholder="Ask about any project..." required style="resize: vertical;"></textarea>
      
      <div style="text-align: left; margin-top: 1.5rem;">
        <button type="submit" class="btn btn-loading">
          <span class="btn-text">Send Enquiry</span>
        </button>
      </div>
    </form>
  </section>
</Base>
