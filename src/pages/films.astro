---
import Base from '../layouts/Base.astro';
import CloudflareStream from '../components/CloudflareStream.astro';
import { getCollection } from 'astro:content';
const filmEntries = await getCollection('films');
const films = filmEntries.sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
---

<Base title="Films | Demetris Yiapanis">
  <h2 class="page-title">Filmography</h2>
  <p class="page-subtitle">Film school projects &amp; directorial work</p>

  <div class="grid-auto" style="margin-top: 2rem;">
    {films.map(f => <article class="card" style="overflow: hidden; padding: 0;">
      {f.data.poster && <div style="width: 100%; aspect-ratio: 2/3; overflow: hidden;">
        <img src={f.data.poster} alt={`${f.data.title} poster`} style="width: 100%; height: 100%; object-fit: cover;" loading="lazy" />
      </div>}
      {!f.data.poster && <div style="width: 100%; aspect-ratio: 2/3; overflow: hidden; background: var(--surface); display: flex; align-items: center; justify-content: center;"
        <p style="color: var(--muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em;">No poster</p>
      </div>}
      <div style="padding: 1.5rem;">
        <h3 style="font-family: var(--font-display); font-weight: 400; font-size: 1.2rem; margin-bottom: 0.5rem;">
          {f.data.title}
        </h3>
        <p style="font-size: 0.75rem; color: var(--accent); letter-spacing: 0.05em; margin-bottom: 1rem;">
          {f.data.genre.join(' • ')} {f.data.type && `• ${f.data.type}`} {f.data.year && `• ${f.data.year}`}
        </p>
        <p style="font-size: 0.85rem; color: var(--muted); line-height: 1.6;">{f.data.synopsis}</p>
        {f.data.videoUrl && <div style="margin-top: 1.5rem;">
          <CloudflareStream videoId={f.data.videoUrl} />
        </div>}
      </div>
    </article>)}
  </div>
</Base>
