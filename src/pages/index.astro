---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const profileEntries = await getCollection('profile');
const profile = profileEntries[0];
---

<Base title="Demetris Yiapanis | Director & Screenwriter">
  <!-- Hero header image -->
  <div class="hero">
    <div class="hero-inner"></div>
  </div>

  <div class="profile-grid">
    <!-- Left: Identity -->
    <div style="text-align: center;">
      <h1 style="font-family: var(--font-serif); font-weight: 400; font-style: italic; font-size: 2.5rem; margin-bottom: 1rem;">
        Demetri
      </h1>
      <img src="/images/profile.jpg" alt="Demetris Yiapanis" class="profile-photo" />
      <p style="font-size: 0.8rem; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 2rem;">
        Director &amp; Screenwriter
      </p>
      <a href="mailto:demetris@yiapanis.co" class="btn">Contact Me</a>
    </div>

    <!-- Right: Bio -->
    <div>
      {profile ? (
        <article class="prose" set:html={profile.body} />
      ) : (
        <p>No profile content yet.</p>
      )}
    </div>
  </div>

  <style>
    .hero {
      width: 100vw;
      margin-left: calc(-50vw + 50%);
      margin-right: calc(-50vw + 50%);
      height: 360px;
      background-image: url('/images/hero-bg.jpg');
      background-repeat: no-repeat;
      background-position: center 59%;
      background-size: cover;
      border-bottom: 1px solid var(--border);
      background-attachment: fixed;
    }
    .hero-inner {
      max-width: 1100px;
      margin: 0 auto;
      height: 100%;
      padding: 0 1.5rem;
    }
    .prose p { margin-bottom: 1.2rem; max-width: 65ch; font-size: 0.95rem; }
    .prose p:first-child { margin-top: 0; }
  </style>
</Base>
