---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(p => ({ params: { slug: p.slug }, props: { post: p } }));
}

const { post } = Astro.props;
const formattedDate = new Date(post.data.date).toLocaleDateString('en-AU', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Base title={`${post.data.title} | Demetris Yiapanis`}>
  <nav style="margin-bottom: 2rem;">
    <a href="/blog" style="font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.15em; color: var(--muted);" >← Back to Journal</a>
  </nav>

  <h1 class="page-title" style="font-size: 1.8rem;">{post.data.title}</h1>
  <p style="font-size:0.75rem; color:var(--muted); margin-bottom:2rem; text-transform: uppercase; letter-spacing: 0.05em;">{formattedDate}</p>

  <article class="prose" set:html={post.body} />

  <hr style="border: none; border-top: 1px solid var(--border); margin: 3rem 0 1.5rem;" />
  <nav>
    <a href="/blog" style="font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.15em; color: var(--muted);" >← Back to Journal</a>
  </nav>
</Base>

<style is:global>
  .prose p { margin-bottom: 1.2rem; line-height: 1.8; font-size: 0.95rem; }
  .prose p:first-child { margin-top: 0; }
  .prose em { font-style: italic; color: var(--muted); }
  .prose strong { font-weight: 500; color: var(--fg); }
  .prose blockquote {
    border-left: 2px solid var(--accent);
    padding-left: 1.5rem;
    margin: 1.5rem 0;
    color: var(--muted);
    font-style: italic;
  }
</style>
