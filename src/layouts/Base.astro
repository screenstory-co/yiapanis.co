---
export interface Props {
  title: string;
}
const { title } = Astro.props;
const nav = [
  { href: '/', label: 'Profile' },
  { href: '/films', label: 'Films' },
  { href: '/in-development', label: 'In Development' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Contact' },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;600&family=Montserrat:wght@300;400;500;700&family=Lora:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" />
  <style is:global>
    :root {
      --bg: #0f0f0f;
      --fg: #e8e8e8;
      --accent: #c9a050;
      --muted: #999;
      --surface: #1a1a1a;
      --border: #2a2a2a;
      --font-display: 'Josefin Sans', sans-serif;
      --font-body: 'Montserrat', sans-serif;
      --font-serif: 'Lora', serif;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--font-body);
      background: var(--bg);
      color: var(--fg);
      line-height: 1.7;
      font-weight: 300;
      -webkit-font-smoothing: antialiased;
    }
    a { color: var(--fg); text-decoration: none; transition: color .2s; }
    a:hover { color: var(--accent); }
    img { max-width: 100%; height: auto; display: block; }
    ::selection { background: var(--accent); color: var(--bg); }

    .container { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; }

    /* Navigation */
    .site-header {
      position: sticky; top: 0; z-index: 100;
      background: rgba(15,15,15,0.9);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border);
    }
    .header-inner {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.2rem 1rem;
      position: relative;
    }
    .hamburger {
      display: none;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.5rem;
      flex-direction: column;
      gap: 5px;
      position: absolute;
      right: 1rem;
      top: 50%;
      transform: translateY(-50%);
    }
    .hamburger span {
      display: block;
      width: 24px;
      height: 1px;
      background: var(--fg);
      transition: all 0.3s;
    }
    .site-nav {
      display: flex; justify-content: center; gap: 2.5rem;
    }
    .site-nav a {
      text-transform: uppercase;
      font-size: 0.72rem;
      letter-spacing: 0.2em;
      font-weight: 500;
      opacity: 0.6;
      position: relative;
    }
    .site-nav a:hover, .site-nav a[aria-current="page"] { opacity: 1; color: var(--accent); }
    .site-nav a[aria-current="page"]::after {
      content: ''; position: absolute; bottom: -4px; left: 0; right: 0;
      height: 1px; background: var(--accent);
    }

    /* Typography */
    .page-title {
      font-family: var(--font-display);
      font-weight: 300;
      font-size: 2rem;
      letter-spacing: 0.05em;
      margin-bottom: 0.5rem;
    }
    .page-subtitle {
      font-family: var(--font-serif);
      font-style: italic;
      color: var(--muted);
      font-size: 1rem;
      font-weight: 400;
    }
    .section-title {
      font-family: var(--font-display);
      font-weight: 300;
      font-size: 1.1rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--accent);
      margin: 3rem 0 1.5rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--border);
    }

    /* Buttons */
    .btn {
      display: inline-block;
      border: 1px solid var(--fg);
      padding: 0.7rem 1.6rem;
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      font-weight: 500;
      transition: all .25s;
      background: transparent;
      color: var(--fg);
      cursor: pointer;
    }
    .btn:hover { background: var(--fg); color: var(--bg); }
    .btn-accent {
      border-color: var(--accent);
      color: var(--accent);
    }
    .btn-accent:hover { background: var(--accent); color: var(--bg); }

    /* Cards */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      padding: 2rem;
      transition: border-color .2s, transform .2s;
    }
    .card:hover { border-color: var(--accent); transform: translateY(-2px); }

    /* Form fields */
    .field-label {
      display: block;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 0.5rem;
      color: var(--muted);
    }
    .field-input {
      width: 100%;
      padding: 0.8rem;
      background: var(--surface);
      border: 1px solid var(--border);
      color: var(--fg);
      font-family: var(--font-body);
      font-size: 0.9rem;
      outline: none;
      transition: border-color .2s;
    }
    .field-input:focus { border-color: var(--accent); }
    .field-input::placeholder { color: var(--muted); opacity: 0.5; }

    /* Grid */
    .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: 2rem; }
    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
    .grid-auto { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; }

    /* Profile grid */
    .profile-grid {
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: 4rem;
      align-items: start;
      padding: 3rem 0;
    }

    /* Gallery */
    .gallery {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 1rem;
      margin: 2rem 0;
    }
    .gallery img {
      width: 100%;
      height: 200px;
      object-fit: cover;
      border-radius: 2px;
      cursor: pointer;
      transition: transform 0.2s;
    }
    .gallery img:hover { transform: scale(1.02); }
    .prose img {
      max-width: 100%;
      height: auto;
      margin: 1.5rem 0;
      border-radius: 2px;
    }
    .prose figure {
      margin: 1.5rem 0;
    }
    .prose figcaption {
      font-size: 0.8rem;
      color: var(--muted);
      font-style: italic;
      margin-top: 0.5rem;
    }

    /* Footer */
    .site-footer {
      text-align: center; padding: 3rem 1rem;
      font-size: 0.7rem; color: var(--muted);
      border-top: 1px solid var(--border);
      margin-top: 4rem;
    }

    @media (max-width: 768px) {
      .hamburger { display: flex; }
      .header-inner { justify-content: flex-start; padding: 1rem; }
      .site-nav {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: rgba(15,15,15,0.95);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--border);
        flex-direction: column;
        gap: 1.5rem;
        padding: 1.5rem;
        text-align: center;
      }
      .site-nav.open { display: flex; }
      .grid-2, .grid-3 { grid-template-columns: 1fr; }
      .grid-auto { grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
      .page-title { font-size: 1.6rem; }
      .profile-grid { grid-template-columns: 1fr; gap: 2rem; padding: 2rem 0; }
    }
  </style>
</head>
<body>
  <header class="site-header">
    <div class="header-inner">
      <button type="button" class="hamburger" aria-label="Toggle menu" aria-expanded="false" aria-controls="site-nav">
        <span></span>
        <span></span>
        <span></span>
      </button>
      <nav class="site-nav" id="site-nav" aria-label="Main">
        {nav.map(item => <a href={item.href} aria-current={Astro.url.pathname === item.href || Astro.url.pathname === item.href + '/' ? 'page' : undefined}>{item.label}</a>)}
      </nav>
    </div>
  </header>

  <main class="container">
    <slot />
  </main>

  <footer class="site-footer">
    &copy; <span id="footer-year">2025</span> Demetris Yiapanis. All Rights Reserved.
  </footer>

  <script is:inline>
    (function() {
      var hamburger = document.querySelector('.hamburger');
      var nav = document.getElementById('site-nav');
      if (!hamburger || !nav) return;
      hamburger.addEventListener('click', function() {
        var expanded = hamburger.getAttribute('aria-expanded') === 'true';
        hamburger.setAttribute('aria-expanded', String(!expanded));
        nav.classList.toggle('open');
      });
    })();
  </script>
</body>
</html>
